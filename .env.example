PORT=3000
NODE_ENV=development
SESSION_SECRET=replace-with-a-long-random-string

# MSSQL (Azure / AWS RDS)
DB_SERVER=your-server.database.windows.net
DB_DATABASE=glovebox_monitoring
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# SMTP – E-Mail Versand
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@glovebox-monitoring.com
EMAIL_PASS=your-email-password

# KeT Kontakt-Mail (Empfänger für Servicenachrichten und Neuregistrierungen)
KET_EMAIL=info@glovebox-monitoring.com
