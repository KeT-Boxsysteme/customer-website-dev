<%- include('../partials/head', { title: 'Set New Password' }) %>
<body class="auth-page">
  <div class="auth-container">
    <h1 class="brand-title">
      <span class="brand-main">Glovebox-Monitoring by KeT</span>
    </h1>

    <%- include('../partials/flash') %>

    <form class="auth-form" action="/auth/reset-password/<%= token %>" method="POST">
      <div class="form-group">
        <label for="password">New Password</label>
        <input type="password" id="password" name="password" required>
      </div>
      <div class="form-group">
        <label for="passwordConfirm">Confirm New Password</label>
        <input type="password" id="passwordConfirm" name="passwordConfirm" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Set New Password</button>
    </form>
  </div>
<%- include('../partials/footer') %>
