<%- include('../partials/head', { title: 'Register' }) %>
<body class="auth-page">
  <div class="auth-container auth-container--wide">
    <h1 class="brand-title">
      <span class="brand-main">Glovebox-Monitoring by KeT</span>
    </h1>

    <%- include('../partials/flash') %>

    <form class="auth-form" action="/auth/register" method="POST" id="registerForm">

      <!-- Company Type Selection -->
      <div class="company-type-selector">
        <label class="type-btn" id="type-university">
          <input type="radio" name="companyType" value="university" required> University
        </label>
        <label class="type-btn" id="type-startup">
          <input type="radio" name="companyType" value="startup"> Startup
        </label>
        <label class="type-btn" id="type-company">
          <input type="radio" name="companyType" value="company"> Company
        </label>
      </div>

      <!-- Fields appear after type selection -->
      <div id="companyFields" class="form-section" style="display:none">

        <!-- Company / University Details -->
        <p class="form-section-title" id="companySectionTitle">Company Details</p>

        <div class="form-group">
          <label for="companyName" id="companyNameLabel">Company Name</label>
          <input type="text" id="companyName" name="companyName" autocomplete="organization">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="street">Street</label>
            <input type="text" id="street" name="street" autocomplete="street-address">
          </div>
          <div class="form-group form-group--small">
            <label for="housenumber">No.</label>
            <input type="text" id="housenumber" name="housenumber">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group form-group--small">
            <label for="zip">ZIP Code</label>
            <input type="text" id="zip" name="zip" autocomplete="postal-code">
          </div>
          <div class="form-group">
            <label for="city">City</label>
            <input type="text" id="city" name="city" autocomplete="address-level2">
          </div>
        </div>

        <hr class="form-divider">

        <!-- Contact Person -->
        <p class="form-section-title">Contact Person</p>

        <div class="form-row">
          <div class="form-group">
            <label for="firstname">First Name</label>
            <input type="text" id="firstname" name="firstname" autocomplete="given-name">
          </div>
          <div class="form-group">
            <label for="lastname">Last Name</label>
            <input type="text" id="lastname" name="lastname" autocomplete="family-name">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="email">E-Mail Address</label>
            <input type="email" id="email" name="email" autocomplete="email">
          </div>
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" autocomplete="tel">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group form-group--small">
            <label for="username">
              User Abbreviation
              <span class="hint">(max. 4 chars)</span>
            </label>
            <input type="text" id="username" name="username" maxlength="4"
                   style="text-transform:uppercase" autocomplete="off">
          </div>
          <div class="form-group">
            <!-- University department -->
            <div id="deptUniversity" style="display:none">
              <label for="deptUni">Department</label>
              <select id="deptUni" name="department">
                <option value="university_management">University Management</option>
                <option value="project_management">Project Management</option>
                <option value="plant_officer">Plant Officer</option>
                <option value="other">Other</option>
              </select>
            </div>
            <!-- Startup / Company department -->
            <div id="deptBusiness" style="display:none">
              <label for="deptBiz">Department</label>
              <select id="deptBiz" name="department">
                <option value="management">Executive Management</option>
                <option value="department_lead">Department Lead</option>
                <option value="plant_officer">Plant Officer</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>
        </div>

        <!-- "Other" position free-text -->
        <div class="form-group" id="deptOtherField" style="display:none">
          <label for="departmentOther">Your Position</label>
          <input type="text" id="departmentOther" name="departmentOther">
        </div>

        <hr class="form-divider">

        <!-- Password -->
        <p class="form-section-title">Set Password</p>

        <div class="form-row">
          <div class="form-group">
            <label for="password">Password</label>
            <div class="input-wrapper">
              <input type="password" id="password" name="password" autocomplete="new-password">
              <button type="button" class="toggle-pw" data-target="password" title="Show / hide password">&#128065;</button>
            </div>
          </div>
          <div class="form-group">
            <label for="passwordConfirm">Confirm Password</label>
            <div class="input-wrapper">
              <input type="password" id="passwordConfirm" name="passwordConfirm" autocomplete="new-password">
              <button type="button" class="toggle-pw" data-target="passwordConfirm" title="Show / hide password">&#128065;</button>
            </div>
            <span class="pw-match-hint" id="pwMatchHint"></span>
          </div>
        </div>

        <hr class="form-divider">

        <div class="form-group form-group--checkbox">
          <label>
            <input type="checkbox" name="agb" id="agb">
            I agree to the <a href="/agb" target="_blank">Terms and Conditions</a>
          </label>
        </div>

        <button type="submit" class="btn btn-primary btn-full" id="submitBtn" disabled>
          Register
        </button>
      </div>
    </form>

    <p class="auth-link">Already have an account? <a href="/auth/login">Login here</a></p>
  </div>

  <script>
    const radios        = document.querySelectorAll('input[name="companyType"]');
    const companyFields = document.getElementById('companyFields');
    const deptUniWrap   = document.getElementById('deptUniversity');
    const deptBizWrap   = document.getElementById('deptBusiness');
    const deptOther     = document.getElementById('deptOtherField');
    const submitBtn     = document.getElementById('submitBtn');
    const agbCheck      = document.getElementById('agb');

    // --- Company type selection ---
    radios.forEach(r => {
      r.addEventListener('change', () => {
        companyFields.style.display = 'block';
        document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));
        r.closest('.type-btn').classList.add('selected');

        const isUni = r.value === 'university';
        document.getElementById('companySectionTitle').textContent =
          isUni ? 'University Details' : 'Company Details';
        document.getElementById('companyNameLabel').textContent =
          isUni ? 'University Name' : 'Company / Startup Name';

        if (isUni) {
          deptUniWrap.style.display = 'block';
          deptBizWrap.style.display = 'none';
          document.getElementById('deptUni').name = 'department';
          document.getElementById('deptBiz').name = '';
        } else {
          deptUniWrap.style.display = 'none';
          deptBizWrap.style.display = 'block';
          document.getElementById('deptBiz').name = 'department';
          document.getElementById('deptUni').name = '';
        }
        checkDeptOther();
        updateSubmitBtn();
      });
    });

    // --- Department "Other" visibility ---
    ['deptUni', 'deptBiz'].forEach(id => {
      document.getElementById(id).addEventListener('change', () => {
        checkDeptOther();
        updateSubmitBtn();
      });
    });

    function checkDeptOther() {
      const active = document.querySelector('select[name="department"]');
      deptOther.style.display = (active && active.value === 'other') ? 'block' : 'none';
    }

    // --- Password show/hide ---
    document.querySelectorAll('.toggle-pw').forEach(btn => {
      btn.addEventListener('click', function () {
        var input = document.getElementById(this.dataset.target);
        var showing = input.type === 'text';
        input.type = showing ? 'password' : 'text';
        this.style.opacity = showing ? '1' : '0.4';
      });
    });

    // --- Password match indicator ---
    ['password', 'passwordConfirm'].forEach(id => {
      document.getElementById(id).addEventListener('input', checkPasswordMatch);
    });

    function checkPasswordMatch() {
      var pw      = document.getElementById('password').value;
      var confirm = document.getElementById('passwordConfirm').value;
      var hint    = document.getElementById('pwMatchHint');
      if (!confirm) { hint.textContent = ''; hint.className = 'pw-match-hint'; return; }
      if (pw === confirm) {
        hint.textContent = '✓ Passwords match';
        hint.className   = 'pw-match-hint pw-match-ok';
      } else {
        hint.textContent = '✗ Passwords do not match';
        hint.className   = 'pw-match-hint pw-match-err';
      }
      updateSubmitBtn();
    }

    // --- Submit button enable/disable ---
    agbCheck.addEventListener('change', updateSubmitBtn);
    document.getElementById('registerForm').addEventListener('input', updateSubmitBtn);

    function updateSubmitBtn() {
      const type = document.querySelector('input[name="companyType"]:checked');
      const requiredFields = [
        'companyName','street','housenumber','zip','city',
        'firstname','lastname','email','phone','username',
        'password','passwordConfirm'
      ];
      const allFilled = requiredFields.every(id => document.getElementById(id).value.trim() !== '');
      const pw      = document.getElementById('password').value;
      const confirm = document.getElementById('passwordConfirm').value;
      submitBtn.disabled = !(type && allFilled && agbCheck.checked && pw === confirm);
    }
  </script>
<%- include('../partials/footer') %>
