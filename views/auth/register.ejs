<%- include('../partials/head', { title: 'Register' }) %>
<body class="auth-page">

  <div class="auth-shell auth-shell--wide">
    <div class="auth-card">

      <div class="auth-brand">
        <span class="auth-brand__main">Glovebox-Monitoring by KeT</span>
      </div>

      <%- include('../partials/flash') %>

      <form id="registerForm" action="/auth/register" method="POST">

        <!-- Step 1: Company type -->
        <div class="type-tabs">
          <label class="type-tab" id="tab-university">
            <input type="radio" name="companyType" value="university" required>
            University
          </label>
          <label class="type-tab" id="tab-startup">
            <input type="radio" name="companyType" value="startup">
            Startup
          </label>
          <label class="type-tab" id="tab-company">
            <input type="radio" name="companyType" value="company">
            Company
          </label>
        </div>

        <!-- Step 2: All fields (shown after type selection) -->
        <div id="companyFields" style="display:none">

          <!-- Organisation -->
          <div class="auth-section-head" id="companySectionTitle">Company Details</div>

          <div class="auth-field">
            <label for="companyName" id="companyNameLabel">Company Name</label>
            <input type="text" id="companyName" name="companyName"
                   placeholder="Acme GmbH" autocomplete="organization">
          </div>

          <div class="auth-row">
            <div class="auth-field">
              <label for="street">Street</label>
              <input type="text" id="street" name="street"
                     placeholder="Musterstraße" autocomplete="street-address">
            </div>
            <div class="auth-field auth-field--xs">
              <label for="housenumber">No.</label>
              <input type="text" id="housenumber" name="housenumber" placeholder="12a">
            </div>
          </div>

          <div class="auth-row">
            <div class="auth-field auth-field--xs">
              <label for="zip">ZIP</label>
              <input type="text" id="zip" name="zip"
                     placeholder="12345" autocomplete="postal-code">
            </div>
            <div class="auth-field">
              <label for="city">City</label>
              <input type="text" id="city" name="city"
                     placeholder="Berlin" autocomplete="address-level2">
            </div>
          </div>

          <!-- Contact Person -->
          <div class="auth-section-head">Contact Person</div>

          <div class="auth-row">
            <div class="auth-field">
              <label for="firstname">First Name</label>
              <input type="text" id="firstname" name="firstname"
                     placeholder="Max" autocomplete="given-name">
            </div>
            <div class="auth-field">
              <label for="lastname">Last Name</label>
              <input type="text" id="lastname" name="lastname"
                     placeholder="Mustermann" autocomplete="family-name">
            </div>
          </div>

          <div class="auth-row">
            <div class="auth-field">
              <label for="email">E-Mail Address</label>
              <input type="email" id="email" name="email"
                     placeholder="max@acme.de" autocomplete="email">
            </div>
            <div class="auth-field">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone"
                     placeholder="+49 123 456789" autocomplete="tel">
            </div>
          </div>

          <div class="auth-row">
            <div class="auth-field auth-field--xs">
              <label for="username">
                Abbreviation
                <span class="field-hint">max. 4</span>
              </label>
              <input type="text" id="username" name="username" maxlength="4"
                     placeholder="MAMU" style="text-transform:uppercase" autocomplete="off">
            </div>
            <div class="auth-field" style="flex:1">
              <!-- University departments -->
              <div id="deptUniversity" style="display:none">
                <label for="deptUni">Department</label>
                <select id="deptUni" name="department">
                  <option value="university_management">University Management</option>
                  <option value="project_management">Project Management</option>
                  <option value="plant_officer">Plant Officer</option>
                  <option value="other">Other (specify below)</option>
                </select>
              </div>
              <!-- Business departments -->
              <div id="deptBusiness" style="display:none">
                <label for="deptBiz">Department</label>
                <select id="deptBiz" name="department">
                  <option value="management">Executive Management</option>
                  <option value="department_lead">Department Lead</option>
                  <option value="plant_officer">Plant Officer</option>
                  <option value="other">Other (specify below)</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Free-text for "Other" position -->
          <div class="auth-field" id="deptOtherField" style="display:none">
            <label for="departmentOther">Your Position</label>
            <input type="text" id="departmentOther" name="departmentOther"
                   placeholder="Enter your role">
          </div>

          <!-- Password -->
          <div class="auth-section-head">Password</div>

          <div class="auth-row">
            <div class="auth-field">
              <label for="password">Password</label>
              <div class="pw-field">
                <input type="password" id="password" name="password"
                       placeholder="••••••••" autocomplete="new-password">
                <button type="button" class="pw-eye" data-target="password" title="Show / hide">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
            </div>
            <div class="auth-field">
              <label for="passwordConfirm">Confirm Password</label>
              <div class="pw-field">
                <input type="password" id="passwordConfirm" name="passwordConfirm"
                       placeholder="••••••••" autocomplete="new-password">
                <button type="button" class="pw-eye" data-target="passwordConfirm" title="Show / hide">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </div>
              <span class="pw-hint" id="pwMatchHint"></span>
            </div>
          </div>

          <!-- AGB + Submit -->
          <div class="agb-row">
            <input type="checkbox" name="agb" id="agb">
            <label for="agb">
              I agree to the <a href="/agb" target="_blank">Terms and Conditions</a>
            </label>
          </div>

          <button type="submit" class="auth-btn-submit" id="submitBtn" disabled>
            Create Account
          </button>

        </div><!-- /companyFields -->
      </form>

      <div class="auth-footer">
        <p>Already have an account? <a href="/auth/login">Login here</a></p>
      </div>

    </div>
  </div>

  <script>
    var eyeOpen   = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    var eyeClosed = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';

    var radios        = document.querySelectorAll('input[name="companyType"]');
    var companyFields = document.getElementById('companyFields');
    var deptUniWrap   = document.getElementById('deptUniversity');
    var deptBizWrap   = document.getElementById('deptBusiness');
    var deptOther     = document.getElementById('deptOtherField');
    var submitBtn     = document.getElementById('submitBtn');
    var agbCheck      = document.getElementById('agb');

    // Company type selection
    radios.forEach(function(r) {
      r.addEventListener('change', function() {
        companyFields.style.display = 'block';
        document.querySelectorAll('.type-tab').forEach(function(b) { b.classList.remove('active'); });
        r.closest('.type-tab').classList.add('active');

        var isUni = r.value === 'university';
        document.getElementById('companySectionTitle').textContent =
          isUni ? 'University Details' : 'Company Details';
        document.getElementById('companyNameLabel').textContent =
          isUni ? 'University Name' : 'Company / Startup Name';

        if (isUni) {
          deptUniWrap.style.display = 'block';
          deptBizWrap.style.display = 'none';
          document.getElementById('deptUni').name = 'department';
          document.getElementById('deptBiz').name = '';
        } else {
          deptUniWrap.style.display = 'none';
          deptBizWrap.style.display = 'block';
          document.getElementById('deptBiz').name = 'department';
          document.getElementById('deptUni').name = '';
        }
        checkDeptOther();
        updateSubmitBtn();
      });
    });

    // Department "Other" visibility
    ['deptUni', 'deptBiz'].forEach(function(id) {
      document.getElementById(id).addEventListener('change', function() {
        checkDeptOther();
        updateSubmitBtn();
      });
    });

    function checkDeptOther() {
      var active = document.querySelector('select[name="department"]');
      deptOther.style.display = (active && active.value === 'other') ? 'block' : 'none';
    }

    // Password show/hide
    document.querySelectorAll('.pw-eye').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var targetId = this.dataset.target;
        if (!targetId) return;
        var input   = document.getElementById(targetId);
        var showing = input.type === 'text';
        input.type  = showing ? 'password' : 'text';
        this.innerHTML = showing ? eyeOpen : eyeClosed;
      });
    });

    // Password match indicator
    ['password', 'passwordConfirm'].forEach(function(id) {
      document.getElementById(id).addEventListener('input', checkPasswordMatch);
    });

    function checkPasswordMatch() {
      var pw      = document.getElementById('password').value;
      var confirm = document.getElementById('passwordConfirm').value;
      var hint    = document.getElementById('pwMatchHint');
      if (!confirm) { hint.textContent = ''; hint.className = 'pw-hint'; return; }
      if (pw === confirm) {
        hint.textContent = '✓ Passwords match';
        hint.className   = 'pw-hint pw-hint--ok';
      } else {
        hint.textContent = '✗ Passwords do not match';
        hint.className   = 'pw-hint pw-hint--err';
      }
      updateSubmitBtn();
    }

    // Submit button state
    agbCheck.addEventListener('change', updateSubmitBtn);
    document.getElementById('registerForm').addEventListener('input', updateSubmitBtn);

    function updateSubmitBtn() {
      var type = document.querySelector('input[name="companyType"]:checked');
      var requiredFields = [
        'companyName','street','housenumber','zip','city',
        'firstname','lastname','email','phone','username',
        'password','passwordConfirm'
      ];
      var allFilled = requiredFields.every(function(id) {
        return document.getElementById(id).value.trim() !== '';
      });
      var pw      = document.getElementById('password').value;
      var confirm = document.getElementById('passwordConfirm').value;
      submitBtn.disabled = !(type && allFilled && agbCheck.checked && pw === confirm);
    }
  </script>

<%- include('../partials/footer') %>
