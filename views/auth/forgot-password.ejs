<%- include('../partials/head', { title: 'Forgot Password' }) %>
<body class="auth-page">
  <div class="auth-container">
    <h1 class="brand-title">
      <span class="brand-main">Glovebox-Monitoring by KeT</span>
    </h1>

    <%- include('../partials/flash') %>

    <p class="auth-desc">Enter your email address and we will send you a password reset link.</p>

    <form class="auth-form" action="/auth/forgot-password" method="POST">
      <div class="form-group">
        <label for="email">E-Mail Address</label>
        <input type="email" id="email" name="email" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Send Reset Link</button>
    </form>

    <p class="auth-link"><a href="/auth/login">Back to Login</a></p>
  </div>
<%- include('../partials/footer') %>
