<%- include('../partials/head', { title: 'Dashboard' }) %>
<body class="app-layout">
  <%- include('../partials/nav', { currentPage: 'dashboard' }) %>

  <main class="main-content">

    <%- include('../partials/flash') %>

    <!-- Hero -->
    <div class="dash-hero">
      <div class="dash-hero__inner">
        <p class="dash-hero__eyebrow" id="dashGreetingLabel">
          <svg width="6" height="6" viewBox="0 0 8 8" fill="currentColor" style="opacity:0.6"><circle cx="4" cy="4" r="4"/></svg>
          Welcome back
        </p>
        <h1 class="dash-hero__name">
          Welcome to <span class="dash-hero__brand">Glovebox-Monitoring by KeT</span>
        </h1>
        <p class="dash-hero__greeting">
          Hello, <span><%= user.firstname %> <%= user.lastname %></span>
        </p>
        <div class="dash-hero__meta">
          <span class="dash-hero__badge dash-badge--<%= user.role %>">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <%= user.role.replace('_', ' ').toUpperCase() %>
          </span>
          <% if (user.department) { %>
            <span class="dash-hero__dept"><%= user.department.replace(/_/g, ' ') %></span>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Quick Access -->
    <div class="dash-grid">

      <!-- Monitoring: all roles -->
      <a href="/monitoring" class="dash-card">
        <div class="dash-card__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
        </div>
        <div>
          <p class="dash-card__title">Monitoring</p>
          <p class="dash-card__desc">Record O₂, H₂O and temperature values for your gloveboxes and track their current status.</p>
        </div>
        <div class="dash-card__cta">
          Open Monitoring
          <span class="dash-card__cta-arrow">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>

      <!-- Diagrams: all roles -->
      <a href="/diagrams" class="dash-card">
        <div class="dash-card__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6"  y1="20" x2="6"  y2="14"/>
          </svg>
        </div>
        <div>
          <p class="dash-card__title">Diagrams</p>
          <p class="dash-card__desc">View time-series charts for O₂, H₂O and fridge temperature over the last 6 to 12 months.</p>
        </div>
        <div class="dash-card__cta">
          View Diagrams
          <span class="dash-card__cta-arrow">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>

      <!-- Box Management: admin + controller -->
      <% if (user.role === 'admin' || user.role === 'controller') { %>
      <a href="/boxes" class="dash-card">
        <div class="dash-card__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <div>
          <p class="dash-card__title">Box Management</p>
          <p class="dash-card__desc">Add, edit and configure gloveboxes including sensors, maintenance intervals and equipment.</p>
        </div>
        <div class="dash-card__cta">
          Manage Boxes
          <span class="dash-card__cta-arrow">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
      <% } %>

      <!-- User Management: admin only -->
      <% if (user.role === 'admin') { %>
      <a href="/users" class="dash-card">
        <div class="dash-card__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
          </svg>
        </div>
        <div>
          <p class="dash-card__title">User Management</p>
          <p class="dash-card__desc">Create accounts for team members, assign roles and manage access to this platform.</p>
        </div>
        <div class="dash-card__cta">
          Manage Users
          <span class="dash-card__cta-arrow">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
      <% } %>

    </div>

    <!-- Account info -->
    <div class="dash-info-strip">
      <div class="dash-info-item">
        <span class="dash-info-item__label">Abbreviation</span>
        <span class="dash-info-item__value"><%= user.username || '-' %></span>
      </div>
      <div class="dash-info-item">
        <span class="dash-info-item__label">E-Mail</span>
        <span class="dash-info-item__value"><%= user.email %></span>
      </div>
      <% if (user.department) { %>
      <div class="dash-info-item">
        <span class="dash-info-item__label">Department</span>
        <span class="dash-info-item__value"><%= user.department.replace(/_/g, ' ') %></span>
      </div>
      <% } %>
      <% if (user.phone) { %>
      <div class="dash-info-item">
        <span class="dash-info-item__label">Phone</span>
        <span class="dash-info-item__value"><%= user.phone %></span>
      </div>
      <% } %>
    </div>

  </main>

  <script>
    var h = new Date().getHours();
    var label = h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';
    document.getElementById('dashGreetingLabel').textContent = label;
  </script>

<%- include('../partials/footer') %>
